# ─────────────────────────────────────────────────────────────────────────────
# GradiumOS v3 — Backend Environment Variables
# Copy to .env and fill in every blank value before starting the server.
# All vars are validated at startup by src/config/env.ts (Zod schema).
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4002                  # Backend listen port (default: 4000 if unset)
NODE_ENV=development       # development | test | production

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://gradium:gradium@localhost:5433/gradium_v3?schema=public   # Prisma connection string; must point to gradium_v3 schema

# ── Auth (JWT) ────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-min-32-chars-access   # HMAC-SHA256 secret for access tokens (min 32 chars)
JWT_REFRESH_SECRET=change-me-min-32-chars-refresh  # HMAC-SHA256 secret for refresh tokens (min 32 chars, different from access)
JWT_ACCESS_TTL=15m         # Access token TTL (e.g. 15m, 1h, 8h)
JWT_REFRESH_TTL_DAYS=7     # Refresh token TTL in days (integer)

# ── Ed25519 signing (Signal tokens, Board Brief, accreditation export) ────────
# Both keys are required together. If absent, a keypair is auto-generated and
# persisted to backend/.keys/ (dev only — never use auto-generated keys in prod).
# Generate a fresh keypair:
#   node -e "const {ed25519}=require('@noble/curves/ed25519');const k=ed25519.utils.randomPrivateKey();const pub=ed25519.getPublicKey(k);console.log('PRIV:',Buffer.from(k).toString('hex'));console.log('PUB:',Buffer.from(pub).toString('hex'))"
SIGNAL_PRIVATE_KEY_HEX=    # Ed25519 private key hex (32 bytes / 64 hex chars)
SIGNAL_PUBLIC_KEY_HEX=     # Corresponding Ed25519 public key hex (32 bytes / 64 hex chars); must match published-keys.json

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Leave GROQ_API_KEY blank to run in deterministic mock mode (no AI calls).
GROQ_API_KEY=              # Groq API key (https://console.groq.com); blank = mock mode
GROQ_MODEL=llama-3.1-70b-versatile   # Groq model ID; must be a Groq free-tier model

# ── Resend email ──────────────────────────────────────────────────────────────
# Leave blank to skip all email sends (safe for local dev and integration tests).
RESEND_API_KEY=            # Resend API key (https://resend.com); blank = emails silently skipped

# ── Feature flags (env-var overrides — take precedence over DB FeatureFlag rows) ──
FEATURE_TUTOR_ENABLED=true               # Override DB flag TUTOR_ENABLED (true/false)
FEATURE_SPONSORED_PATHWAYS_ENABLED=true  # Override DB flag SPONSORED_PATHWAYS_ENABLED
FEATURE_VERIFIER_WIDGET_ENABLED=true     # Override DB flag VERIFIER_WIDGET_ENABLED
FEATURE_PROCTORING_ENABLED=false         # Override DB flag PROCTORING_ENABLED

# ── File uploads ──────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads       # Local directory for uploaded JDs and curricula (relative to backend/)

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info             # trace | debug | info | warn | error

# ── Demo mode ─────────────────────────────────────────────────────────────────
DEMO_MODE=false            # Set to true to enable demo-safe read-only overrides (port 5170 hero stats)

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=                # Sentry DSN; empty = Sentry disabled (safe in dev)

# ── Git metadata (injected by CI) ─────────────────────────────────────────────
GIT_COMMIT=                # Git SHA injected at build time; surfaced on /api/v1/health

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production, set to your Vercel URLs.
# Local dev defaults: Campus 5273 | Workforce 5275 | Talent 5277
ALLOWED_ORIGINS=http://localhost:5273,http://localhost:5275,http://localhost:5277
# Production example (set in Railway dashboard):
# ALLOWED_ORIGINS=https://campus.yourdomain.vercel.app,https://workforce.yourdomain.vercel.app,https://talent.yourdomain.vercel.app
